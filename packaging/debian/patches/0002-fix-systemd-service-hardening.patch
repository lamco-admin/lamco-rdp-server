Description: Fix systemd service hardening issues found during VM testing
 - Move StartLimitIntervalSec/Burst from [Service] to [Unit] section
 - Remove ProtectHome=read-only (hangs KDE plasmashell)
 - Remove ProtectHostname=yes (not needed for user service)
 - Remove CapabilityBoundingSet/AmbientCapabilities (crash in unprivileged
   environments like Ubuntu 24.04 in Proxmox)
 - Add mount/umount2 syscalls for FUSE clipboard support
Author: Greg Lamberson <greg@lamco.io>
Last-Update: 2026-03-03

--- a/packaging/systemd/lamco-rdp-server.service
+++ b/packaging/systemd/lamco-rdp-server.service
@@ -18,6 +18,8 @@
 Documentation=https://github.com/lamco-admin/lamco-rdp-server
 After=graphical-session.target
 Wants=graphical-session.target
+StartLimitIntervalSec=60
+StartLimitBurst=3

 # Require a graphical session - we need Wayland compositor access
 ConditionEnvironment=WAYLAND_DISPLAY
@@ -32,8 +34,6 @@
 # Restart on failure, but not too aggressively
 Restart=on-failure
 RestartSec=5
-StartLimitIntervalSec=60
-StartLimitBurst=3

 # Environment
 Environment=RUST_LOG=info
@@ -41,7 +41,6 @@
 # Filesystem hardening
 NoNewPrivileges=yes
 ProtectSystem=strict
-ProtectHome=read-only
 PrivateTmp=yes
 ProtectProc=invisible
 ProcSubset=pid
@@ -58,7 +57,6 @@
 ProtectKernelLogs=yes
 ProtectControlGroups=yes
 ProtectClock=yes
-ProtectHostname=yes
 LockPersonality=yes
 MemoryDenyWriteExecute=yes
 RestrictRealtime=yes
@@ -70,13 +68,10 @@
 # Network: only TCP (RDP listening)
 RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX

-# Capability bounding (user service has no caps by default, but be explicit)
-CapabilityBoundingSet=
-AmbientCapabilities=
-
-# Syscall filtering: allow only what an RDP server needs
+# Syscall filtering: allow system-service baseline plus mount/umount for FUSE clipboard
 SystemCallFilter=@system-service
 SystemCallFilter=~@privileged @resources
+SystemCallFilter=mount umount2
 SystemCallArchitectures=native

 [Install]
